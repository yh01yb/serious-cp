#include <bits/stdc++.h>
using namespace std;

#define ll long long
#define pb push_back
#define all(x) x.begin(), x.end()
#define allr(x) x.rbegin(), x.rend()
#define len(a) (int)a.size()
#define endl "\n"

void solve()
{
    int n;
    cin >> n;

    vector<ll> a(n), b(n), c(n);
    for (int i = 0; i < n; i++) cin >> a[i];
    for (int i = 0; i < n; i++) cin >> b[i];
    for (int i = 0; i < n; i++) cin >> c[i];

    vector<pair<ll,int>> A, B, C;

    for (int i = 0; i < n; i++) {
        A.pb({a[i], i});
        B.pb({b[i], i});
        C.pb({c[i], i});
    }

    sort(allr(A));
    sort(allr(B));
    sort(allr(C));

    ll ans = 0;

    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            for (int k = 0; k < 3; k++) {
                int x = A[i].second;
                int y = B[j].second;
                int z = C[k].second;

                if (x != y && y != z && x != z) {
                    ans = max(ans, A[i].first + B[j].first + C[k].first);
                }
            }
        }
    }

    cout << ans << endl;
}

int main()
{
    ios_base::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);

    int t;
    cin >> t;
    while (t--)
    {
        solve();
    }
    return 0;
}