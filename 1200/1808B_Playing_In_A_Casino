#include <bits/stdc++.h>
using namespace std;

#define ll long long
#define pb push_back
#define all(x) x.begin(), x.end()
#define allr(x) x.rbegin(), x.rend()
#define len(a) (int)a.size()
#define endl "\n"

void solve()
{
    ll n, m;
    cin >> n >> m;

    vector<vector<ll>> v(m, vector<ll>(n));

    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < m; j++)
        {
            cin >> v[j][i];
        }
    }

    ll ans = 0;

    for (int i = 0; i < m; i++)
    {
        sort(all(v[i]));

        for (int j =
             0; j < n; j++)
        {
            ans -= v[i][j] * (n - j - 1);
            ans += v[i][j] * j;
        }
    }

    cout << ans << endl;
}
int main()
{
    ios_base::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);

    int t;
    cin >> t;
    while (t--)
    {
        solve();
    }
    return 0;
}